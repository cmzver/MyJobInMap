# FieldWorker — корневой .env (ОПЦИОНАЛЬНО)
# ==========================================
# Этот файл читает ТОЛЬКО docker-compose — для подстановки переменных вида
# ${PORT}, ${ENVIRONMENT}, ${POSTGRES_*} в docker-compose*.yml.
# Само приложение его НЕ читает.
#
# Конфигурация приложений живёт в отдельных per-service файлах:
#   • Сервер / API   → server/.env   (см. server/.env.example)
#   • Telegram-бот   → bot/.env      (см. bot/.env.example)
# Секреты (SECRET_KEY, токен бота и т.д.) задавайте ТАМ, а не здесь.
#
# Всё в этом файле опционально — у каждой переменной есть значение по умолчанию
# в compose-файлах. Копируйте в .env только чтобы переопределить дефолты:
#   cp .env.example .env

# ============================================
# Параметры docker-compose
# ============================================

# Окружение контейнеров (development | staging | production)
ENVIRONMENT=production

# Внешний порт, на котором API публикуется на хосте.
# Контейнер внутри всегда слушает 8001.
PORT=8001

# ============================================
# Только для docker-compose.postgres.yml
# ============================================
# Учётные данные контейнера PostgreSQL (профиль с БД Postgres).
# POSTGRES_USER=fieldworker
# POSTGRES_PASSWORD=change_me_in_production
# POSTGRES_DB=fieldworker_db
