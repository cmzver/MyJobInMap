# Пример WG-пира для доступа к домофонным панелям.
# Скопируйте в wg-intercom.conf и подставьте реальные значения.
# РЕАЛЬНЫЙ ФАЙЛ НЕ КОММИТИТЬ (он в .gitignore).
#
# Важно:
#   - AllowedIPs сужен до панельных подсетей — туннель НЕ перехватывает
#     остальной трафик контейнера (интернет, postgres, redis работают как обычно);
#   - PersistentKeepalive держит туннель за NAT (для on-demand-сессий важно);
#   - один и тот же пир нельзя одновременно держать на двух хостах
#     (ноутбук + прод) — будет конфликт. Для прода лучше отдельный пир.

[Interface]
Address = 192.168.17.10/26
PrivateKey = <PROD_PRIVATE_KEY>

[Peer]
PublicKey = <SERVER_PUBLIC_KEY>
PreSharedKey = <PRESHARED_KEY>
Endpoint = 188.187.112.254:13231
AllowedIPs = 10.80.0.0/16, 10.125.0.0/16, 192.168.0.1/32
PersistentKeepalive = 25
