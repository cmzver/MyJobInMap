<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration
    ==============================
    Настройки безопасности сети для FieldWorker.
    
    Development: разрешён HTTP для всех локальных адресов
    Production: для HTTPS удалите cleartextTrafficPermitted="true" из base-config
-->
<network-security-config>
    <!-- 
        Production: только HTTPS.
        Cleartext (HTTP) разрешён только для локальной разработки.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    
    <!-- Разрешаем HTTP для локальных адресов (эмулятор, локальная сеть) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="false">192.168.0.0/16</domain>
    </domain-config>
    
    <!-- Debug builds: доверять пользовательским сертификатам -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>
