# FieldWorker Telegram Bot — Environment Variables
# ================================================
# Скопируйте этот файл как bot/.env и заполните значения:
#   cp bot/.env.example bot/.env
#
# Бот читает переменные из окружения. В Docker они подключаются через
# docker-compose.yml (env_file: ./bot/.env).

# =============================================================================
# Telegram
# =============================================================================
# Токен бота от @BotFather — ОБЯЗАТЕЛЬНО, без него бот не запустится.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# =============================================================================
# Подключение к API
# =============================================================================
# Базовый URL API.
# В Docker значение задаётся compose-файлом (http://api:8001) и переопределяет
# этот файл — менять здесь нужно только при запуске бота без Docker.
# API_BASE_URL=http://127.0.0.1:8001

# Учётные данные бота для аутентификации в API (бот получает JWT сам).
API_USERNAME=
API_PASSWORD=

# Альтернатива логину/паролю — заранее выданный JWT-токен.
# API_TOKEN=

# =============================================================================
# Парсинг сообщений (опционально)
# =============================================================================
# Минимальная длина сообщения, чтобы бот пытался распознать заявку.
# MIN_MESSAGE_LENGTH=20

# Маппинг "чат → исполнитель": chatId=worker,chatId2=worker2
# GROUP_WORKER_MAP=

# TTL кэша бота в секундах.
# BOT_CACHE_TTL=300
