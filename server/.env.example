# FieldWorker Server — Environment Variables
# ============================================
# Скопируйте этот файл как .env и настройте значения:
#   cp .env.example .env
#
# Все переменные опциональны — есть значения по умолчанию.
# Переменные окружения ОС имеют приоритет над значениями из .env.

# =============================================================================
# База данных
# =============================================================================
# SQLite (по умолчанию для разработки):
# DATABASE_URL=sqlite:///./tasks.db

# PostgreSQL (рекомендуется для production):
# DATABASE_URL=postgresql://fieldworker:secure_password@localhost:5432/fieldworker_db

# =============================================================================
# Безопасность (JWT)
# =============================================================================
# Секретный ключ для подписи JWT-токенов — ОБЯЗАТЕЛЬНО сменить в production!
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-super-secret-key-here

# Алгоритм подписи JWT (по умолчанию HS256)
# ALGORITHM=HS256

# Время жизни access-токена в часах (по умолчанию 24)
# ACCESS_TOKEN_EXPIRE_HOURS=24

# Время жизни refresh-токена в днях (по умолчанию 30)
# REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Сервер
# =============================================================================
# Хост и порт
# HOST=0.0.0.0
# PORT=8001

# Окружение: development | staging | production
# В production включаются дополнительные проверки (SECRET_KEY, CORS)
# ENVIRONMENT=development

# =============================================================================
# CORS
# =============================================================================
# Разрешённые origins (через запятую). По умолчанию "*" для разработки.
# В production укажите конкретные домены!
# CORS_ORIGINS=https://example.com,https://admin.example.com

# =============================================================================
# Логирование
# =============================================================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Формат логов: text (для разработки) | json (для ELK/Loki в production)
# LOG_FORMAT=text

# =============================================================================
# Rate Limiting (защита от brute-force)
# =============================================================================
# Макс. попыток логина на IP за окно
# RATE_LIMIT_MAX_ATTEMPTS=5

# Окно rate limiting в секундах
# RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Firebase (Push-уведомления)
# =============================================================================
# Путь к файлу сервисного аккаунта Firebase
# FIREBASE_CREDENTIALS=firebase-service-account.json

# =============================================================================
# Оптимизация изображений
# =============================================================================
# Включить/выключить оптимизацию загружаемых фото
# IMAGE_OPTIMIZATION_ENABLED=true

# Качество JPEG (1-100)
# IMAGE_QUALITY=85

# Макс. ширина/высота в пикселях (с сохранением пропорций)
# IMAGE_MAX_DIMENSION=1920

# Конвертировать все загрузки в WebP
# IMAGE_CONVERT_TO_WEBP=false

# Удалять EXIF-метаданные (GPS, камера и т.д.)
# IMAGE_STRIP_METADATA=true

# Макс. размер загружаемого файла в байтах (по умолчанию 5 МБ)
# MAX_FILE_SIZE=5242880

# =============================================================================
# Геокодинг
# =============================================================================
# Таймаут запроса к геокодеру (секунды)
# GEOCODING_TIMEOUT=5

# Размер LRU-кэша геокодинга
# GEOCODING_CACHE_SIZE=1000

# User-Agent для Nominatim
# GEOCODING_USER_AGENT=fieldworker_app

# =============================================================================
# Автоматические бэкапы
# =============================================================================
# Включить встроенный планировщик бэкапов (APScheduler)
# BACKUP_SCHEDULER_ENABLED=false

# Час запуска ежедневного бэкапа (0-23, по умолчанию 3:00)
# BACKUP_SCHEDULE_HOUR=3

# Минута запуска (0-59)
# BACKUP_SCHEDULE_MINUTE=0

# Макс. срок хранения бэкапов в днях (старые удаляются автоматически)
# BACKUP_RETENTION_DAYS=30
